# ==============================================================================
# JARVIS OS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
# ==============================================================================

# --- Application ---
JARVIS_ENV=development                     # development | production | testing
JARVIS_LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR | CRITICAL
JARVIS_DATA_DIR=./data                     # Root data directory
JARVIS_PLUGINS_DIR=./plugins              # User plugins directory

# --- AI Providers ---
# Set the provider you want to use as default
JARVIS_AI_PROVIDER=claude                  # claude | openai | gemini | local

ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GOOGLE_API_KEY=your-gemini-key-here

# --- AI Model Selection ---
JARVIS_CLAUDE_MODEL=claude-opus-4-5
JARVIS_OPENAI_MODEL=gpt-4o
JARVIS_GEMINI_MODEL=gemini-1.5-pro
JARVIS_LOCAL_MODEL_PATH=./data/models/llama-3-8b.gguf

# --- Voice ---
JARVIS_VOICE_ENABLED=true
JARVIS_WAKE_WORD=jarvis                    # The word that wakes the assistant
JARVIS_WAKE_WORD_SENSITIVITY=0.5          # 0.0 (least sensitive) to 1.0 (most sensitive)
JARVIS_VOICE_INPUT_DEVICE=               # Leave empty for system default
JARVIS_VOICE_OUTPUT_DEVICE=             # Leave empty for system default
JARVIS_STT_PROVIDER=faster-whisper       # faster-whisper | openai-whisper
JARVIS_TTS_PROVIDER=coqui               # coqui | pyttsx3 | openai-tts
JARVIS_TTS_VOICE=                        # Provider-specific voice ID
JARVIS_AUDIO_SAMPLE_RATE=16000
JARVIS_NOISE_REDUCTION=true

# --- Memory ---
JARVIS_MEMORY_ENABLED=true
JARVIS_SHORT_TERM_LIMIT=50              # Max messages in short-term context
JARVIS_LONG_TERM_DB_PATH=./data/memory/long_term/jarvis.db
JARVIS_VECTOR_STORE_PATH=./data/memory/vector_store
JARVIS_EMBEDDING_MODEL=all-MiniLM-L6-v2
JARVIS_MEMORY_RETENTION_DAYS=365

# --- Desktop Automation ---
JARVIS_DESKTOP_ENABLED=true
JARVIS_REQUIRE_CONFIRMATION=true         # Always ask before executing actions
JARVIS_SAFE_MODE=true                    # Disable all destructive actions
JARVIS_ALLOWED_PATHS=~/Documents,~/Downloads,~/Desktop
JARVIS_FORBIDDEN_PATHS=/System,/Library,/usr,/etc

# --- Browser Automation ---
JARVIS_BROWSER_ENABLED=true
JARVIS_BROWSER_DEFAULT=chromium         # chromium | firefox | webkit
JARVIS_BROWSER_HEADLESS=false
JARVIS_BROWSER_TIMEOUT_MS=30000

# --- Security ---
JARVIS_ENCRYPTION_KEY=                   # Auto-generated if empty (stored in keyring)
JARVIS_KEYRING_SERVICE=jarvis-os
JARVIS_AUDIT_LOG_PATH=./data/audit/audit.jsonl
JARVIS_SESSION_SECRET=                   # Auto-generated if empty

# --- UI ---
JARVIS_UI_THEME=dark                     # dark | light | system
JARVIS_UI_ACCENT_COLOR=#7C3AED          # Purple accent
JARVIS_UI_WINDOW_OPACITY=0.97
JARVIS_UI_ALWAYS_ON_TOP=false
JARVIS_UI_START_MINIMIZED=false

# --- Logging ---
JARVIS_LOG_FILE=./data/logs/jarvis.log
JARVIS_LOG_ROTATION=10 MB
JARVIS_LOG_RETENTION=30 days
JARVIS_LOG_FORMAT=json                   # json | pretty

# --- Performance ---
JARVIS_MAX_CONCURRENT_TASKS=5
JARVIS_AI_TIMEOUT_SECONDS=60
JARVIS_VOICE_LATENCY_TARGET_MS=200
